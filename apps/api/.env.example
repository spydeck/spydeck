# Local Postgres, or a managed host like Neon (add ?sslmode=require for managed)
DATABASE_URL=postgresql://socialplanner:socialplanner@localhost:5432/socialplanner

# ScrapeCreators API key — required to sync social posts (https://scrapecreators.com)
SCRAPECREATORS_API_KEY=
# Apify API key — optional
APIFY_API_KEY=

REDIS_HOST=localhost
REDIS_PORT=6379

# Redis URL for response caching on /ads/* endpoints (1 hour TTL).
# If unset, the API falls back to an in-memory cache store.
REDIS_URL=redis://localhost:6379

# JWT secret for httpOnly cookie auth — generate with: openssl rand -base64 32
JWT_SECRET=
# Seed the first admin user: pnpm --filter api db:seed-user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
