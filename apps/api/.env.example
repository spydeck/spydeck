# Local Postgres, or a managed host like Neon (add ?sslmode=require for managed)
DATABASE_URL=postgresql://socialplanner:socialplanner@localhost:5432/socialplanner

# ScrapeCreators API key — required to sync social posts (https://scrapecreators.com)
SCRAPECREATORS_API_KEY=
# Apify API key — optional
APIFY_API_KEY=

REDIS_HOST=localhost
REDIS_PORT=6379
