# Copy to `.env` (read automatically by docker compose) and fill in.

# --- Database ---
# Leave DATABASE_URL unset to use the bundled postgres service (recommended for
# self-hosting). Set it to a Neon / managed Postgres URL to use that instead —
# the standard pg driver connects to either (add ?sslmode=require for managed PG).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Credentials for the bundled postgres container (only used when DATABASE_URL is unset)
POSTGRES_USER=socialplanner
POSTGRES_PASSWORD=socialplanner
POSTGRES_DB=socialplanner

# --- Networking ---
# Origin allowed by the API's CORS (the web app)
WEB_ORIGIN=http://localhost:3000

# URL the BROWSER uses to reach the API.
# By default, '/api' is used, which leverages Next.js Server-Side Rewrites
# to proxy requests to the backend container (INTERNAL_API_URL).
# Keep it as '/api' to remain environment-agnostic.
NEXT_PUBLIC_API_URL=/api

# Internal backend URL used by Next.js Server-Side Rewrites to proxy client requests.
# Within the docker-compose network, this is http://api:4000
INTERNAL_API_URL=http://api:4000
