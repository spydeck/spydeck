# Copy to `.env` (read automatically by docker compose) and fill in.
# For Coolify: set these in the app's Environment Variables UI instead.

# --- Admin user (REQUIRED) ---
# Seeded into the database on first boot. This is the only thing you must set.
# A first-run wizard will replace this later.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- Everything below is optional ---

# JWT secret. Leave unset to auto-generate a UUID on first boot (persisted to the
# api-data volume). Set it only if you want to pin a specific value.
# JWT_SECRET=

# Database. Leave unset to use the bundled postgres service. Set to a Neon /
# managed Postgres URL to use that instead (add ?sslmode=require for managed PG).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Credentials for the bundled postgres container (only used when DATABASE_URL is unset)
# POSTGRES_USER=socialplanner
# POSTGRES_PASSWORD=socialplanner
# POSTGRES_DB=socialplanner

# Origin allowed by the API's CORS (the web app). Set to your public URL in prod.
# WEB_ORIGIN=http://localhost:3000

# URL the BROWSER uses to reach the API. Default '/api' proxies via Next.js
# rewrites to INTERNAL_API_URL, keeping the build environment-agnostic.
# NEXT_PUBLIC_API_URL=/api
# INTERNAL_API_URL=http://api:4000
